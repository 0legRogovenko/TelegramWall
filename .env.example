# ── Telegram Bot ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdef...
TELEGRAM_WEBHOOK_URL=https://your-app.onrender.com
TELEGRAM_ADMIN_IDS=123456789

# ── Telethon Userbot ──────────────────────────────────────────
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890
TELEGRAM_PHONE=+7900...
TELEGRAM_SESSION_STRING=           # run auth_userbot.py to get this

# ── Database (Supabase Transaction Pooler) ────────────────────
DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?sslmode=require

# ── Anthropic (optional — enables /summary and AI filter) ─────
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-haiku-4-5        # summaries & digest
# CLAUDE_FILTER_MODEL=claude-haiku-4-5  # AI relevance filter

# ── Payments ──────────────────────────────────────────────────
# Leave empty to use Telegram Stars (default)
YOOKASSA_PROVIDER_TOKEN=

# ── Optional overrides ────────────────────────────────────────
# CHANNEL_LIMIT_FREE=3
# CHANNEL_LIMIT_BASIC=10
# TRIAL_DAYS=3
# REFERRAL_BONUS_DAYS=3
# DIGEST_HOUR_UTC=8
# POST_RETENTION_DAYS=3
# ADMIN_REPORT_HOUR_UTC=7      # ежедневный отчёт админам (7 UTC = 10 МСК)
# Пороги сторожа (HEARTBEAT_STALE_MINUTES, REALERT_HOURS) задаются не здесь:
# он живёт отдельным job'ом — Settings → Secrets and variables → Variables.
# FLASK_SECRET_KEY=change-me
# FLASK_PORT=5001
